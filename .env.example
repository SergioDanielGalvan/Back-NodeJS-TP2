# Copiá este archivo a .env y completá los valores reales.
# .env NO se commitea (ya está en .gitignore).

# --- Conexión a MongoDB ---
# Local:
MONGODB_URI=mongodb://127.0.0.1:27017/TP2-IFTS29

# Atlas (ejemplo; reemplazá usuario, password URL-encodeada y cluster):
# MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/TP2-IFTS29?appName=TP2-IFTS29

# Nombre de la base (se fuerza desde el código aunque no esté en la URI)
MONGODB_DB=TP2-IFTS29

# --- JWT ---
# Clave para firmar/verificar los tokens. Poné una larga y aleatoria.
JWT_SECRET=cambiame-por-una-clave-larga-y-aleatoria
JWT_EXPIRES=8h
